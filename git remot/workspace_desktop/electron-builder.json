{
  "publish": [
    {
      "provider": "generic",
      "url": "https://releases.mattermost.com/desktop"
    }
  ],
  "appId": "Workspace.Desktop",
  "artifactName": "${version}/Workspace-${version}-${os}-${arch}.${ext}",
  "directories": {
    "buildResources": "src/assets",
    "output": "release"
  },
  "extraMetadata": {
    "main": "index.js"
  },
  "files": [
    "!node_modules/**/*",
    "node_modules/bindings/**/*",
    "node_modules/file-uri-to-path/**/*",
    "node_modules/macos-notification-state/**/*",
    "node_modules/windows-focus-assist/**/*",
    "node_modules/registry-js/**/*",
    "node_modules/uiohook-napi/**/*",
    "node_modules/@nut-tree-fork/**/*",
    "node_modules/jimp/**/*",
