    "node_modules/aproba/**/*",
    "node_modules/arch/**/*",
    "node_modules/are-we-there-yet/**/*",
    "node_modules/base64-js/**/*",
    "node_modules/bl/**/*",
    "node_modules/bmp-js/**/*",
    "node_modules/buffer/**/*",
    "node_modules/buffer-equal/**/*",
    "node_modules/centra/**/*",
